{
  "name": "spin-to-win",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:yandex": "npm run build:yandex && node scripts/serve-yandex-local.mjs",
    "build": "tsc && vite build",
    "build:yandex": "tsc && vite build --mode yandex --outDir dist-yandex",
    "package:yandex": "npm run build:yandex && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-yandex.ps1",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run"
  },
  "dependencies": {
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@types/three": "^0.184.1",
    "typescript": "^5.5.4",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
